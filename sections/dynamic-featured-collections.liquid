{{ 'section-collections.css' | asset_url | stylesheet_tag }}

<section class="featured-collections">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header">
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="section-subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="collections-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign collection_handle = block.settings.collection -%}
          {%- assign collection = collections[collection_handle] -%}
          
          {%- if collection != blank -%}
            <a href="{{ collection.url }}" class="collection-card glass-card" {{ block.shopify_attributes }}>
              <div class="collection-image">
                {%- if collection.image -%}
                  <img src="{{ collection.image | img_url: '600x' }}" 
                       alt="{{ collection.title | escape }}"
                       loading="lazy">
                {%- elsif collection.products.first and collection.products.first.featured_image -%}
                  <img src="{{ collection.products.first.featured_image | img_url: '600x' }}" 
                       alt="{{ collection.title | escape }}"
                       loading="lazy">
                {%- else -%}
                  <div class="collection-placeholder">
                    <span class="collection-icon">{{ block.settings.icon }}</span>
                  </div>
                {%- endif -%}
                
                <div class="collection-overlay">
                  <span class="collection-count">{{ collection.products_count }} Products</span>
                </div>
              </div>
              
              <div class="collection-info">
                <h3 class="collection-title">{{ collection.title }}</h3>
                {%- if collection.description != blank -%}
                  <p class="collection-description">{{ collection.description | strip_html | truncate: 100 }}</p>
                {%- endif -%}
                <span class="collection-link-text">
                  Shop Now →
                </span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- comment %} Auto-display collections if no blocks configured {%- endcomment -%}
        {%- for collection in collections limit: 8 -%}
          {%- unless collection.handle == 'frontpage' -%}
            <a href="{{ collection.url }}" class="collection-card glass-card">
              <div class="collection-image">
                {%- if collection.image -%}
                  <img src="{{ collection.image | img_url: '600x' }}" 
                       alt="{{ collection.title | escape }}"
                       loading="lazy">
                {%- elsif collection.products.first -%}
                  <img src="{{ collection.products.first.featured_image | img_url: '600x' }}" 
                       alt="{{ collection.title | escape }}"
                       loading="lazy">
                {%- endif -%}
                
                <div class="collection-overlay">
                  <span class="collection-count">{{ collection.products_count }} Products</span>
                </div>
              </div>
              
              <div class="collection-info">
                <h3 class="collection-title">{{ collection.title }}</h3>
                {%- if collection.description != blank -%}
                  <p class="collection-description">{{ collection.description | strip_html | truncate: 100 }}</p>
                {%- endif -%}
                <span class="collection-link-text">Shop Now →</span>
              </div>
            </a>
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div class="section-footer">
        <a href="/collections" class="btn btn-primary">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .featured-collections {
    padding: 80px 0;
    background: var(--color-light-bg);
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-dark-text);
    opacity: 0.8;
  }

  .collections-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
    margin-bottom: 48px;
  }

  .collection-card {
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .collection-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
  }

  .collection-image {
    position: relative;
    padding-top: 75%;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
    background: var(--color-light-bg);
  }

  .collection-image img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collection-card:hover .collection-image img {
    transform: scale(1.1);
  }

  .collection-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--color-navy), var(--color-green));
  }

  .collection-icon {
    font-size: 4rem;
  }

  .collection-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    transform: translateY(100%);
    transition: transform 0.3s ease;
  }

  .collection-card:hover .collection-overlay {
    transform: translateY(0);
  }

  .collection-count {
    color: var(--color-white);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .collection-info {
    padding: 24px;
  }

  .collection-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .collection-description {
    color: var(--color-dark-text);
    opacity: 0.8;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .collection-link-text {
    color: var(--color-green);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.3s ease;
  }

  .collection-card:hover .collection-link-text {
    gap: 12px;
  }

  .section-footer {
    text-align: center;
  }

  @media (max-width: 768px) {
    .featured-collections {
      padding: 60px 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .collections-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse our complete collection of B.Pharmacy study materials"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (Emoji)",
          "default": "📚",
          "info": "Used if collection has no image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections"
    }
  ]
}
{% endschema %}
