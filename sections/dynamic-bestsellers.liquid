{{ 'section-products.css' | asset_url | stylesheet_tag }}

<section class="bestsellers-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="section-subtitle">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="products-grid">
      {%- liquid
        assign collection_handle = section.settings.collection
        if collection_handle != blank
          assign collection = collections[collection_handle]
          assign products_to_show = section.settings.products_to_show
        else
          comment
            If no collection specified, show best-selling products from all collections
          endcomment
          assign products_to_show = section.settings.products_to_show
        endif
      -%}

      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'dynamic-product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- comment %} Show products from all collections sorted by best-selling {%- endcomment -%}
        {%- for product in collections.all.products limit: products_to_show -%}
          {% render 'dynamic-product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and collection != blank -%}
      <div class="section-footer">
        <a href="{{ collection.url }}" class="btn btn-primary">
          {{ section.settings.button_text }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .bestsellers-section {
    padding: 80px 0;
    background: var(--color-white);
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-dark-text);
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
    margin-bottom: 48px;
  }

  .section-footer {
    text-align: center;
  }

  @media (max-width: 768px) {
    .bestsellers-section {
      padding: 60px 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .products-grid {
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
    }
  }
</style>

{% schema %}
{
  "name": "Bestsellers",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestselling Notes"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Most popular study materials chosen by students"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Leave empty to show best-selling products from all collections"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Products to Show"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show View All Button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Products"
    }
  ],
  "presets": [
    {
      "name": "Bestsellers"
    }
  ]
}
{% endschema %}
