{{ 'section-semester-categories.css' | asset_url | stylesheet_tag }}

<section class="semester-categories">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header">
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="section-subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="semester-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="semester-card glass-card">
          <div class="semester-card__icon">
            {{ block.settings.icon }}
          </div>
          <h3 class="semester-card__title">{{ block.settings.title }}</h3>
          <p class="semester-card__description">{{ block.settings.description }}</p>
          <div class="semester-card__footer">
            <span class="semester-card__count">{{ block.settings.product_count }} Notes</span>
            <span class="semester-card__arrow">→</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .semester-categories {
    padding: 80px 0;
    background: var(--color-light-bg);
  }

  .section-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-dark-text);
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
  }

  .semester-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }

  .semester-card {
    padding: 32px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .semester-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--color-green), var(--color-accent-green));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .semester-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.15);
  }

  .semester-card:hover::before {
    transform: scaleX(1);
  }

  .semester-card__icon {
    font-size: 3rem;
    margin-bottom: 20px;
    display: inline-block;
    animation: bounce 2s infinite;
  }

  .semester-card:hover .semester-card__icon {
    animation: none;
    transform: scale(1.1) rotate(5deg);
    transition: transform 0.3s ease;
  }

  .semester-card__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .semester-card__description {
    color: var(--color-dark-text);
    opacity: 0.8;
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .semester-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .semester-card__count {
    font-weight: 600;
    color: var(--color-green);
    font-size: 0.95rem;
  }

  .semester-card__arrow {
    font-size: 1.5rem;
    color: var(--color-navy);
    transition: transform 0.3s ease;
  }

  .semester-card:hover .semester-card__arrow {
    transform: translateX(8px);
  }

  @media (max-width: 768px) {
    .semester-categories {
      padding: 60px 0;
    }

    .section-title {
      font-size: 2rem;
    }

    .semester-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .semester-card {
      padding: 24px;
    }
  }
</style>

