{{ 'section-footer.css' | asset_url | stylesheet_tag }}

<footer class="footer" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="footer__container container">
    <!-- Footer Top -->
    <div class="footer__top">
      <div class="footer__column footer__column--about">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | img_url: '150x' }}" 
               alt="{{ shop.name }}" 
               class="footer__logo"
               loading="lazy">
        {%- else -%}
          <h3 class="footer__brand">{{ shop.name }}</h3>
        {%- endif -%}
        
        {%- if section.settings.description != blank -%}
          <p class="footer__description">{{ section.settings.description }}</p>
        {%- endif -%}

        <!-- Social Links -->
        {%- if section.settings.show_social -%}
          <div class="footer__social">
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="social-link" aria-label="Facebook" target="_blank">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="social-link" aria-label="Instagram" target="_blank">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_youtube_link != blank -%}
              <a href="{{ settings.social_youtube_link }}" class="social-link" aria-label="YouTube" target="_blank">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </a>
            {%- endif -%}
            
            {%- if settings.social_telegram_link != blank -%}
              <a href="{{ settings.social_telegram_link }}" class="social-link" aria-label="Telegram" target="_blank">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer__column">
            <h4 class="footer__heading">{{ block.settings.heading }}</h4>
            {%- if block.settings.menu != blank -%}
              <ul class="footer__menu">
                {%- for link in linklists[block.settings.menu].links -%}
                  <li class="footer__menu-item">
                    <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Newsletter -->
      {%- if section.settings.show_newsletter -%}
        <div class="footer__column footer__column--newsletter">
          <h4 class="footer__heading">{{ section.settings.newsletter_heading }}</h4>
          <p class="footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
          
          <form action="/contact#newsletter" method="post" class="footer__newsletter-form">
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input type="email" 
                   name="contact[email]" 
                   placeholder="Enter your email" 
                   class="footer__newsletter-input"
                   required>
            <button type="submit" class="footer__newsletter-submit">
              Subscribe
            </button>
          </form>
        </div>
      {%- endif -%}
    </div>

    <!-- Footer Bottom -->
    <div class="footer__bottom">
      <div class="footer__bottom-left">
        <p class="footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        </p>
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment-icons">
          <img src="https://cdn.shopify.com/s/files/1/0070/7032/files/payment-icons.png" alt="Payment methods" loading="lazy">
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 60px 0 30px;
    margin-top: 80px;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px;
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__column--about {
    max-width: 350px;
  }

  .footer__logo {
    margin-bottom: 20px;
  }

  .footer__brand {
    font-size: 1.75rem;
    font-weight: 800;
    margin-bottom: 20px;
  }

  .footer__description {
    line-height: 1.6;
    opacity: 0.9;
    margin-bottom: 24px;
  }

  .footer__social {
    display: flex;
    gap: 12px;
  }

  .social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: var(--color-green);
    transform: translateY(-4px);
  }

  .footer__heading {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .footer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__menu-item {
    margin-bottom: 12px;
  }

  .footer__link {
    opacity: 0.9;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .footer__link:hover {
    opacity: 1;
    transform: translateX(4px);
    color: var(--color-green);
  }

  .footer__newsletter-text {
    opacity: 0.9;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .footer__newsletter-form {
    display: flex;
    gap: 8px;
  }

  .footer__newsletter-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.1);
    color: inherit;
    font-size: 0.95rem;
  }

  .footer__newsletter-input::placeholder {
    color: inherit;
    opacity: 0.6;
  }

  .footer__newsletter-submit {
    padding: 12px 24px;
    background: var(--color-green);
    color: var(--color-white);
    border: none;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .footer__newsletter-submit:hover {
    background: var(--color-accent-green);
    transform: translateY(-2px);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }

  .footer__copyright {
    opacity: 0.8;
    font-size: 0.9rem;
  }

  .footer__payment-icons img {
    height: 30px;
    opacity: 0.8;
  }

  @media (max-width: 1024px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
    }

    .footer__column--about {
      grid-column: 1 / -1;
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding: 40px 0 20px;
      margin-top: 60px;
    }

    .footer__top {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .footer__newsletter-form {
      flex-direction: column;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Your trusted source for premium B.Pharmacy study materials. Helping students excel in their pharmaceutical education."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Links",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#072B6B"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show Newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Stay Updated"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter Text",
      "default": "Subscribe to get updates on new notes and exclusive offers."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show Payment Icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list",
        "settings": {
          "heading": "Quick Links",
          "menu": "footer"
        }
      },
      {
        "type": "link_list",
        "settings": {
          "heading": "Support",
          "menu": "footer"
        }
      }
    ]
  }
}
{% endschema %}
