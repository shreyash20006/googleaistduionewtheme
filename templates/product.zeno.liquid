{{ 'template-product.css' | asset_url | stylesheet_tag }}

<div class="product-page">
  <div class="container">
    <div class="product-layout">
      <!-- Product Images -->
      <div class="product-images">
        <div class="product-main-image">
          {%- if product.featured_media -%}
            <img src="{{ product.featured_media | img_url: '800x' }}" 
                 alt="{{ product.featured_media.alt | escape }}"
                 id="main-product-image">
          {%- endif -%}

          <!-- Badges -->
          <div class="product-badges">
            {%- if product.compare_at_price > product.price -%}
              {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
              <span class="badge badge-discount">-{{ discount }}% OFF</span>
            {%- endif -%}
            
            {%- if product.tags contains 'bestseller' -%}
              <span class="badge badge-bestseller">🔥 Bestseller</span>
            {%- endif -%}
          </div>
        </div>

        {%- if product.media.size > 1 -%}
          <div class="product-thumbnails">
            {%- for media in product.media limit: 5 -%}
              <button class="thumbnail {% if forloop.first %}active{% endif %}" 
                      data-media-id="{{ media.id }}">
                <img src="{{ media | img_url: '150x' }}" alt="{{ media.alt | escape }}">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Product Info -->
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p class="product-vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-title">{{ product.title }}</h1>

        <!-- Rating -->
        <div class="product-rating">
          <div class="stars">
            <span class="star">⭐</span>
            <span class="star">⭐</span>
            <span class="star">⭐</span>
            <span class="star">⭐</span>
            <span class="star">⭐</span>
          </div>
          <span class="rating-text">(4.8/5 from 250+ reviews)</span>
        </div>

        <!-- Price -->
        <div class="product-price">
          {%- if product.compare_at_price > product.price -%}
            <span class="price-compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="price-current">{{ product.price | money }}</span>
        </div>

        <!-- Features -->
        <ul class="product-features">
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Instant PDF Download
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            High-Quality Handwritten Notes
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Free Lifetime Updates
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M16.667 5L7.5 14.167L3.333 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            24/7 Support Available
          </li>
        </ul>

        <!-- Product Form -->
        {% form 'product', product, id: 'product-form' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          
          {%- unless product.has_only_default_variant -%}
            <div class="product-variants">
              {%- for option in product.options_with_values -%}
                <div class="variant-option">
                  <label>{{ option.name }}</label>
                  <select name="options[{{ option.name | escape }}]" class="variant-select">
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                        {{ value }}
                      </option>
                    {%- endfor -%}
                  </select>
                </div>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <div class="product-actions">
            <button type="submit" 
                    class="btn btn-primary btn-add-to-cart"
                    {% unless product.available %}disabled{% endunless %}>
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M3 3H5L5.4 5M7 13H17L19 5H5.4M7 13L5.4 5M7 13L4.70711 15.2929C4.07714 15.9229 4.52331 17 5.41421 17H17M17 17C15.8954 17 15 17.8954 15 19C15 20.1046 15.8954 21 17 21C18.1046 21 19 20.1046 19 19C19 17.8954 18.1046 17 17 17ZM9 19C9 20.1046 8.10457 21 7 21C5.89543 21 5 20.1046 5 19C5 17.8954 5.89543 17 7 17C8.10457 17 9 17.8954 9 19Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
            </button>

            {% if product.available %}
              <button type="button" class="btn btn-secondary btn-buy-now">
                Buy Now
              </button>
            {% endif %}
          </div>
        {% endform %}

        <!-- Trust Badges -->
        <div class="trust-badges">
          <div class="trust-badge">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Secure Payment</span>
          </div>
          <div class="trust-badge">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M21 10C21 17 12 23 12 23C12 23 3 17 3 10V5L12 2L21 5V10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>7-Day Guarantee</span>
          </div>
          <div class="trust-badge">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Top Rated</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Product Description -->
    <div class="product-description-section">
      <div class="product-tabs">
        <button class="tab-button active" data-tab="description">Description</button>
        <button class="tab-button" data-tab="contents">What's Included</button>
        <button class="tab-button" data-tab="reviews">Reviews</button>
      </div>

      <div class="tab-content active" id="description">
        <div class="description-content">
          {{ product.description }}
        </div>
      </div>

      <div class="tab-content" id="contents">
        <div class="contents-list">
          <h3>This package includes:</h3>
          <ul>
            <li>Complete chapter-wise notes</li>
            <li>Important questions and answers</li>
            <li>Previous year questions (PYQs)</li>
            <li>MCQs for practice</li>
            <li>Quick revision notes</li>
            <li>Diagrams and flowcharts</li>
          </ul>
        </div>
      </div>

      <div class="tab-content" id="reviews">
        <div class="reviews-section">
          <p>Customer reviews coming soon...</p>
        </div>
      </div>
    </div>

    <!-- Related Products -->
    {%- if product.collections.first -%}
      <div class="related-products-section">
        <h2 class="section-title">You May Also Like</h2>
        <div class="products-grid">
          {%- assign collection = product.collections.first -%}
          {%- for related_product in collection.products limit: 4 -%}
            {%- unless related_product.id == product.id -%}
              {% render 'product-card', product: related_product %}
            {%- endunless -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .product-page {
    padding: 40px 0 80px;
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    margin-bottom: 80px;
  }

  .product-main-image {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: var(--color-light-bg);
  }

  .product-main-image img {
    width: 100%;
    height: auto;
  }

  .product-badges {
    position: absolute;
    top: 20px;
    left: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .product-thumbnails {
    display: flex;
    gap: 12px;
    margin-top: 16px;
  }

  .thumbnail {
    width: 80px;
    height: 80px;
    border: 2px solid transparent;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.3s ease;
    background: none;
    padding: 0;
  }

  .thumbnail.active {
    border-color: var(--color-green);
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-vendor {
    color: var(--color-green);
    font-weight: 600;
    margin-bottom: 12px;
  }

  .product-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 20px;
    line-height: 1.2;
  }

  .product-rating {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .product-price {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .price-compare {
    font-size: 1.5rem;
    color: var(--color-dark-text);
    opacity: 0.5;
    text-decoration: line-through;
  }

  .price-current {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--color-green);
  }

  .product-features {
    list-style: none;
    padding: 0;
    margin: 0 0 32px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .product-features li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.05rem;
    color: var(--color-dark-text);
  }

  .product-features svg {
    stroke: var(--color-green);
    flex-shrink: 0;
  }

  .product-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
  }

  .btn-add-to-cart,
  .btn-buy-now {
    flex: 1;
    padding: 18px;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }

  .trust-badges {
    display: flex;
    gap: 24px;
    padding: 24px;
    background: var(--color-light-bg);
    border-radius: 12px;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-dark-text);
  }

  .trust-badge svg {
    stroke: var(--color-green);
  }

  .product-description-section {
    margin-bottom: 80px;
  }

  .product-tabs {
    display: flex;
    gap: 32px;
    border-bottom: 2px solid var(--color-light-bg);
    margin-bottom: 32px;
  }

  .tab-button {
    background: none;
    border: none;
    padding: 16px 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-dark-text);
    opacity: 0.6;
    cursor: pointer;
    position: relative;
    transition: all 0.3s ease;
  }

  .tab-button.active {
    opacity: 1;
    color: var(--color-green);
  }

  .tab-button.active::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-green);
  }

  .tab-content {
    display: none;
  }

  .tab-content.active {
    display: block;
  }

  .description-content {
    line-height: 1.8;
    font-size: 1.05rem;
    color: var(--color-dark-text);
  }

  .related-products-section {
    margin-top: 80px;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 40px;
    text-align: center;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
  }

  @media (max-width: 1024px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .product-title {
      font-size: 2rem;
    }

    .price-current {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .product-actions {
      flex-direction: column;
    }

    .trust-badges {
      flex-direction: column;
      gap: 16px;
    }

    .product-tabs {
      gap: 16px;
      overflow-x: auto;
    }

    .tab-button {
      font-size: 1rem;
      white-space: nowrap;
    }
  }
</style>

<script>
  // Tab switching
  const tabButtons = document.querySelectorAll('.tab-button');
  const tabContents = document.querySelectorAll('.tab-content');

  tabButtons.forEach(button => {
    button.addEventListener('click', () => {
      const tabId = button.dataset.tab;
      
      tabButtons.forEach(btn => btn.classList.remove('active'));
      tabContents.forEach(content => content.classList.remove('active'));
      
      button.classList.add('active');
      document.getElementById(tabId).classList.add('active');
    });
  });

  // Thumbnail switching
  const thumbnails = document.querySelectorAll('.thumbnail');
  const mainImage = document.getElementById('main-product-image');

  thumbnails.forEach(thumb => {
    thumb.addEventListener('click', () => {
      thumbnails.forEach(t => t.classList.remove('active'));
      thumb.classList.add('active');
      mainImage.src = thumb.querySelector('img').src.replace('150x', '800x');
    });
  });

  // Buy Now button
  const buyNowBtn = document.querySelector('.btn-buy-now');
  if (buyNowBtn) {
    buyNowBtn.addEventListener('click', () => {
      document.getElementById('product-form').submit();
      setTimeout(() => {
        window.location.href = '/checkout';
      }, 500);
    });
  }
</script>

        <div class="zn-content product">
          {% assign productKey = 'zeno-product-' | append: product.id %}
          <link rel="stylesheet" href="{{ productKey | append: '.css' | asset_url }}">
          {% include productKey %}
          <script src="{{ productKey | append: '.js' | asset_url }}"></script>
        </div>
      